{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rando2020/Intelligent_Services/schemas/governance_execution_rule.schema.json",
  "title": "Governance Execution Rule Schema",
  "description": "Schema for executable governance rules used by the YAML-driven governed delivery engine.",
  "type": "object",
  "required": [
    "id",
    "name",
    "category",
    "severity",
    "applies_when",
    "finding",
    "required_action",
    "launch_blocker",
    "required_evidence"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 3},
    "name": {"type": "string", "minLength": 3},
    "category": {"type": "string", "minLength": 3},
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "applies_when": {
      "type": "object",
      "description": "Condition tree. Supports all, any, equals, not_equals, contains_any, and min_length."
    },
    "finding": {"type": "string", "minLength": 3},
    "required_action": {"type": "string", "minLength": 3},
    "launch_blocker": {"type": "boolean"},
    "required_evidence": {
      "type": "array",
      "items": {"type": "string"}
    },
    "recommended_ticket": {
      "type": "object",
      "properties": {
        "title": {"type": "string"},
        "owner_role": {"type": "string"},
        "purpose": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
