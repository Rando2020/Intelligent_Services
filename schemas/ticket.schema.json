{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rando2020/Intelligent_Services/schemas/ticket.schema.json",
  "title": "Governed Delivery Ticket Schema",
  "description": "Standard output format for generated Jira, Rally, Asana, or Azure DevOps work items.",
  "type": "object",
  "required": [
    "external_id",
    "work_item_type",
    "title",
    "description",
    "acceptance_criteria",
    "definition_of_done",
    "risk_rating",
    "owner_role"
  ],
  "properties": {
    "external_id": {"type": "string"},
    "parent_external_id": {"type": "string"},
    "platform": {
      "type": "string",
      "enum": ["generic", "jira", "ado", "rally", "asana"]
    },
    "work_item_type": {
      "type": "string",
      "enum": ["initiative", "epic", "feature", "story", "task", "subtask", "bug", "defect", "risk", "approval"]
    },
    "title": {"type": "string"},
    "description": {"type": "string"},
    "business_context": {"type": "string"},
    "user_story": {"type": "string"},
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
    "definition_of_done": {"type": "array", "items": {"type": "string"}},
    "request_type": {"type": "string"},
    "program": {"type": "string"},
    "client": {"type": "string"},
    "systems_impacted": {"type": "array", "items": {"type": "string"}},
    "data_involved": {"type": "array", "items": {"type": "string"}},
    "phi_flag": {"type": "boolean"},
    "pii_flag": {"type": "boolean"},
    "pci_flag": {"type": "boolean"},
    "external_recipient": {"type": "boolean"},
    "file_movement_required": {"type": "boolean"},
    "delivery_method": {"type": "string"},
    "legal_review_required": {"type": "boolean"},
    "security_review_required": {"type": "boolean"},
    "data_governance_required": {"type": "boolean"},
    "qa_required": {"type": "boolean"},
    "soc2_impact": {"type": "array", "items": {"type": "string"}},
    "risk_rating": {"type": "string", "enum": ["L0", "L1", "L2", "L3", "L4", "L5"]},
    "timeline_risk_rating": {"type": "string", "enum": ["L0", "L1", "L2", "L3", "L4", "L5"]},
    "ticket_quality_rating": {"type": "string", "enum": ["L0", "L1", "L2", "L3", "L4", "L5"]},
    "priority": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "owner_role": {"type": "string"},
    "assignee": {"type": "string"},
    "due_date": {"type": "string"},
    "sprint_or_iteration": {"type": "string"},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "evidence_required": {"type": "array", "items": {"type": "string"}},
    "evidence_links": {"type": "array", "items": {"type": "string"}},
    "launch_blocker": {"type": "boolean"},
    "status": {"type": "string"},
    "export_ready": {"type": "boolean"}
  },
  "additionalProperties": true
}
